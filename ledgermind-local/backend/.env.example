# LedgerMind Backend Configuration
# Prefix with LM_ for pydantic-settings

# Database Path (relative to backend directory or absolute)
LM_DB_PATH=data/ledgermind.db

# Vector Store Path (relative to backend directory or absolute)
LM_VECTOR_STORE_PATH=data/vector_store

# Ollama Configuration
LM_OLLAMA_BASE_URL=http://localhost:11434
LM_OLLAMA_MODEL=llama3.2
